<div class="nixie-clock-widget py-2">
	<div class="clock" id="nixie-clock">
		<div class="nixie-tube" id="nc-h1"><span class="digit">0</span><span class="digit">1</span><span class="digit">2</span><span class="digit">3</span><span class="digit">4</span><span class="digit">5</span><span class="digit">6</span><span class="digit">7</span><span class="digit">8</span><span class="digit">9</span></div>
		<div class="nixie-tube" id="nc-h2"><span class="digit">0</span><span class="digit">1</span><span class="digit">2</span><span class="digit">3</span><span class="digit">4</span><span class="digit">5</span><span class="digit">6</span><span class="digit">7</span><span class="digit">8</span><span class="digit">9</span></div>
		<div class="nixie-dot"></div>
		<div class="nixie-tube" id="nc-m1"><span class="digit">0</span><span class="digit">1</span><span class="digit">2</span><span class="digit">3</span><span class="digit">4</span><span class="digit">5</span><span class="digit">6</span><span class="digit">7</span><span class="digit">8</span><span class="digit">9</span></div>
		<div class="nixie-tube" id="nc-m2"><span class="digit">0</span><span class="digit">1</span><span class="digit">2</span><span class="digit">3</span><span class="digit">4</span><span class="digit">5</span><span class="digit">6</span><span class="digit">7</span><span class="digit">8</span><span class="digit">9</span></div>
		<div class="nixie-dot"></div>
		<div class="nixie-tube" id="nc-s1"><span class="digit">0</span><span class="digit">1</span><span class="digit">2</span><span class="digit">3</span><span class="digit">4</span><span class="digit">5</span><span class="digit">6</span><span class="digit">7</span><span class="digit">8</span><span class="digit">9</span></div>
		<div class="nixie-tube" id="nc-s2"><span class="digit">0</span><span class="digit">1</span><span class="digit">2</span><span class="digit">3</span><span class="digit">4</span><span class="digit">5</span><span class="digit">6</span><span class="digit">7</span><span class="digit">8</span><span class="digit">9</span></div>
	</div>
</div>

<script is:inline>
	(function(){
		function updateTube(el, num) {
			el.querySelectorAll('.digit').forEach(function(d){ d.classList.remove('active') });
			el.querySelectorAll('.digit')[num].classList.add('active');
		}
		function tick() {
			var t = new Date();
			var h = t.getHours().toString().padStart(2,'0');
			var m = t.getMinutes().toString().padStart(2,'0');
			var s = t.getSeconds().toString().padStart(2,'0');
			updateTube(document.getElementById('nc-h1'), +h[0]);
			updateTube(document.getElementById('nc-h2'), +h[1]);
			updateTube(document.getElementById('nc-m1'), +m[0]);
			updateTube(document.getElementById('nc-m2'), +m[1]);
			updateTube(document.getElementById('nc-s1'), +s[0]);
			updateTube(document.getElementById('nc-s2'), +s[1]);
		}
		tick(); setInterval(tick, 1000);
	})();
</script>

<style>
	.nixie-clock-widget { display: flex; justify-content: center; }
	.nixie-clock-widget .clock { display: flex; gap: 3px; align-items: center; }
	.nixie-clock-widget .nixie-tube { position: relative; width: 26px; height: 44px; font-family: 'Courier New', monospace; font-weight: bold; }
	.nixie-clock-widget .nixie-tube .digit { position: absolute; top: 0; left: 0; width: 100%; height: 100%; font-size: 34px; text-align: center; line-height: 44px; color: #2a1a0a; opacity: 0.05; transition: all 0.3s ease; }
	.nixie-clock-widget .nixie-tube .digit.active { color: #ff6600; opacity: 1; font-size: 38px; text-shadow: 0 0 8px #ff6600, 0 0 16px rgba(255,102,0,0.7), 0 0 24px rgba(255,102,0,0.4); }
	.nixie-clock-widget .nixie-dot { display: flex; flex-direction: column; gap: 8px; margin: 0 3px; }
	.nixie-clock-widget .nixie-dot::before, .nixie-clock-widget .nixie-dot::after { content: ''; width: 5px; height: 5px; border-radius: 50%; background-color: #ff6600; box-shadow: 0 0 6px #ff6600, 0 0 12px rgba(255,102,0,0.7); }
</style>
